local function createPart(pos, color, name)
    local p = Instance.new("Part")
    p.Size = Vector3.new(6,1,6)
    p.Color = color
    p.Material = Enum.Material.Neon
    p.Anchored = true
    p.CanCollide = false
    p.Position = pos
    p.Name = name
    p.Parent = workspace
end

