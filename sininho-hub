-- FUNÇÃO BOTÃO
local function createButton(text, posY, color, textColor)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 200, 0, 60)
    btn.Position = UDim2.new(0.5, -100, 0, posY)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextScaled = true
    btn.TextColor3 = textColor
    btn.Parent = frame
    return btn
end

